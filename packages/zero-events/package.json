{
  "name": "@rocicorp/zero-events",
  "version": "0.0.4",
  "license": "Apache-2.0",
  "author": "Rocicorp, LLC.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rocicorp/mono.git",
    "directory": "packages/zero-events"
  },
  "files": [
    "out",
    "!*.tsbuildinfo"
  ],
  "type": "module",
  "module": "out/mod.js",
  "types": "out/mod.d.ts",
  "exports": {
    ".": {
      "types": "./out/mod.d.ts",
      "default": "./out/mod.js"
    }
  },
  "scripts": {
    "build": "rm -rf out && tsc && npx tsx tool/build.ts",
    "prepack": "npm run build",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "lint": "oxlint --quiet --config ../../oxlint.config.ts",
    "test": "vitest run",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "devDependencies": {
    "oxfmt": "^0.45.0",
    "shared": "0.0.0",
    "typescript": "~6.0.2"
  }
}
