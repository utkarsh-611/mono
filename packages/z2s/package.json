{
  "name": "z2s",
  "version": "0.0.0",
  "private": true,
  "description": "ZQL to SQL compiler. Used for testing the ZQL implementation and reads inside of custom mutators",
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "lint": "oxlint --type-aware src/",
    "test": "vitest run",
    "test:no-pg": "vitest run --project z2s/no-pg",
    "test:no-pg:watch": "vitest --project z2s/no-pg",
    "test:pg15": "vitest run --project z2s/pg-15",
    "test:pg15:watch": "vitest --project z2s/pg-15",
    "test:pg16": "vitest run --project z2s/pg-16",
    "test:pg16:watch": "vitest --project z2s/pg-16",
    "test:pg17": "vitest run --project z2s/pg-17",
    "test:pg17:watch": "vitest --project z2s/pg-17",
    "test:watch": "vitest watch",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "dependencies": {
    "@databases/escape-identifier": "^1.0.3",
    "@databases/sql": "^3.3.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@types/pg": "^8.11.11",
    "@vitest/runner": "4.1.3",
    "oxfmt": "^0.45.0",
    "pg": "^8.16.3",
    "shared": "0.0.0",
    "vitest": "4.1.3",
    "zero-cache": "0.0.0",
    "zero-protocol": "0.0.0",
    "zero-schema": "0.0.0",
    "zero-types": "0.0.0",
    "zql": "0.0.0"
  }
}
