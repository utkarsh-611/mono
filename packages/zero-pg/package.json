{
  "name": "zero-pg",
  "version": "0.0.0",
  "private": true,
  "description": "Library to help implement custom mutators in a user's API server when they are using Postgres as their database.",
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "check-format": "oxfmt --check .",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "lint": "oxlint --type-aware src/",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "fmt": "oxfmt .",
    "check-fmt": "oxfmt --check ."
  },
  "dependencies": {
    "@rocicorp/logger": "^5.4.0"
  },
  "devDependencies": {
    "@vitest/runner": "4.1.3",
    "oxfmt": "^0.45.0",
    "vitest": "4.1.3",
    "zero-cache": "0.0.0",
    "zero-server": "0.0.0"
  }
}
